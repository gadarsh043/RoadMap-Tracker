rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /roadmapItems/{itemId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll([
          'title', 'description', 'emoji', 'targetDate', 'shippedDate',
          'status', 'statusOverride', 'heartCount', 'sortOrder',
          'createdBy', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.heartCount == 0
        && request.resource.data.statusOverride == false;

      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'description', 'emoji', 'updatedAt']));

      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /hearts/{heartId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && heartId == request.resource.data.itemId + '_' + request.auth.uid;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update: if false;
    }
  }
}
